---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客文章 - TYD Blog" description="所有技术文章">
  <section>
    <h1 class="text-4xl font-bold mb-8">博客文章</h1>
    
    <div class="space-y-6">
      {posts.map((post) => (
        <a href={`/posts/${post.id}`} class="block group">
          <article class="flex flex-col md:flex-row gap-6 p-6 bg-gray-50 dark:bg-gray-800 rounded-xl hover:shadow-lg transition-shadow">
            {post.data.heroImage && (
              <img 
                src={post.data.heroImage} 
                alt={post.data.title}
                class="w-full md:w-48 h-32 object-cover rounded-lg"
              />
            )}
            <div class="flex-1">
              <h2 class="text-xl font-bold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-400 mb-3">
                {post.data.description}
              </p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags && (
                  <div class="flex gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="px-2 py-1 bg-gray-200 dark:bg-gray-700 rounded text-xs">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
    
    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">还没有文章，敬请期待！</p>
      </div>
    )}
  </section>
</BaseLayout>
