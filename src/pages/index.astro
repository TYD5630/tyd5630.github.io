---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const latestPost = posts[0];
const otherPosts = posts.slice(1);
---

<BaseLayout title="TYD Blog - 技术分享与学习记录" description="个人技术博客，分享学习心得与代码经验">
  <!-- Hero Section -->
  <section class="mb-12 text-center py-12">
    <h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
      欢迎来到 TYD Blog
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">
      记录技术思考，分享学习心得
    </p>
    <div class="flex justify-center gap-4">
      <a href="/blog" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        浏览文章
      </a>
      <a href="/rss.xml" class="px-6 py-3 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        RSS 订阅
      </a>
    </div>
  </section>

  <!-- Latest Post -->
  {latestPost && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">最新文章</h2>
      <a href={`/posts/${latestPost.id}`} class="block group">
        <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
          {latestPost.data.heroImage && (
            <img 
              src={latestPost.data.heroImage} 
              alt={latestPost.data.title}
              class="w-full h-64 md:h-96 object-cover group-hover:scale-105 transition-transform duration-300"
            />
          )}
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              {latestPost.data.title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
              {latestPost.data.description}
            </p>
            <time class="text-sm text-gray-500">
              {latestPost.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- Other Posts -->
  {otherPosts.length > 0 && (
    <section>
      <h2 class="text-2xl font-bold mb-6">更多文章</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {otherPosts.map((post) => (
          <a href={`/posts/${post.id}`} class="block group">
            <article class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 hover:shadow-lg transition-shadow h-full">
              <h3 class="text-xl font-bold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-2">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between text-sm text-gray-500">
                <time>
                  {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags && (
                  <span class="text-xs">{post.data.tags.slice(0, 2).join(', ')}</span>
                )}
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Empty State -->
  {posts.length === 0 && (
    <div class="text-center py-12">
      <p class="text-gray-600 dark:text-gray-400 mb-4">还没有文章，敬请期待！</p>
    </div>
  )}
</BaseLayout>
